# ---------------------------------------------------------------------------
# Nuxt (Vercel) environment variables — server-only, never exposed to the browser.
# Copy to `.env` for local dev, and set the same keys in the Vercel dashboard
# (Project → Settings → Environment Variables) for production. See DEPLOY.md.
# ---------------------------------------------------------------------------

# Public URL of the Cloudflare Worker API.
#   Local dev:  http://127.0.0.1:8787
#   Production: https://pharmacy-vitamin-api.<your-subdomain>.workers.dev
WORKER_API_URL=http://127.0.0.1:8787

# Bearer token the Nuxt proxy sends to the Worker. MUST equal the Worker's
# API_TOKEN secret (Cloudflare: `wrangler secret put API_TOKEN`).
WORKER_API_TOKEN=replace-with-a-long-random-dev-secret

# Token that gates the /admin UI. Falls back to WORKER_API_TOKEN if unset.
ADMIN_UI_TOKEN=replace-with-a-long-random-dev-secret
